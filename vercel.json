{
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/fetch-all-arrivals",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/refresh-daily-tape",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/refresh-all-destination-news",
      "schedule": "35-59 14 * * *"
    },
    {
      "path": "/api/refresh-all-destination-news",
      "schedule": "0-30 15 * * *"
    },
    {
      "path": "/api/refresh-weekly-brief",
      "schedule": "0 15 * * 2"
    }
  ]
}
